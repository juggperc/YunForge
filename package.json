{
  "name": "yunforge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n client,server -c blue,green \"pnpm dev:client\" \"pnpm dev:server\"",
    "dev:client": "vite",
    "dev:server": "npm rebuild better-sqlite3 && tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "build:client": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start:server": "npm rebuild better-sqlite3 && tsx server/index.ts",
    "postinstall": "pnpm rebuild better-sqlite3 esbuild"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.25",
    "@ai-sdk/react": "^3.0.118",
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@hono/node-server": "^1.19.11",
    "@hono/zod-validator": "^0.7.6",
    "@openrouter/ai-sdk-provider": "^2.3.3",
    "ai": "^6.0.116",
    "better-sqlite3": "^12.8.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "e2b": "^2.14.1",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "hono": "^4.12.8",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.0.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0"
  }
}
